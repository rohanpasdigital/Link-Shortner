<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Link Not Found</title>

    <style>
        :root {
            --bg: #ffffff;
            --text: #111827;
            --card: #f3f4f6;
            --accent: #6366f1;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #0f172a;
                --text: #e5e7eb;
                --card: #1e293b;
                --accent: #818cf8;
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto;
        }

        body {
            background: var(--bg);
            color: var(--text);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            text-align: center;
            padding: 40px;
            border-radius: 16px;
            background: var(--card);
            max-width: 420px;
            width: 90%;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .logo {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--accent);
        }

        h1 {
            font-size: 60px;
            margin-bottom: 10px;
        }

        p {
            opacity: .8;
            margin-bottom: 30px;
        }

        .button {
            display: inline-block;
            padding: 12px 22px;
            border-radius: 8px;
            text-decoration: none;
            background: var(--accent);
            color: white;
            font-weight: 500;
            transition: .2s;
        }

        .button:hover {
            transform: translateY(-2px);
            opacity: .9;
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="logo">
            Error
        </div>

        <h1>404</h1>

        <p>
            The link you are trying to access does not exist or may have been removed.
        </p>

    </div>

</body>

</html>